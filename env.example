# ================================
# APPLICATION CONFIGURATION
# Application URL (used for verification links in emails)
APP_URL=http://localhost:3000

# Server port
PORT=3000
# Environment (development, production, test)
NODE_ENV=development
# DATABASE CONFIGURATION
# PostgreSQL connection settings
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=barber_db
# JWT AUTHENTICATION
# JWT Secret Key - CHANGE THIS IN PRODUCTION!
JWT_SECRET=your-secret-key-change-in-production-use-long-random-string
# JWT Access Token expiration (e.g., 1h, 1d, 7d)
JWT_EXPIRES_IN=1d
# JWT Refresh Token Secret - CHANGE THIS IN PRODUCTION!
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production
# JWT Refresh Token expiration
JWT_REFRESH_EXPIRES_IN=7d
# EMAIL CONFIGURATION (Nodemailer)
# SMTP Server Configuration
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USER=a560172c769558
MAIL_PASSWORD=54cc08ee191f19
MAIL_FROM=noreply@barber.com
# EMAIL PROVIDER OPTIONS
# Option 1: Gmail (recommended for testing)
# - Enable 2FA on your Google account
# - Generate an App Password: https://myaccount.google.com/apppasswords
# - Use the 16-character app password as MAIL_PASSWORD
#
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=2525
# MAIL_USER=your-gmail@gmail.com
# MAIL_PASSWORD=xxxx xxxx xxxx xxxx
# Option 2: Mailtrap (recommended for development)
# - Sign up at https://mailtrap.io
# - Create an inbox and get credentials
# MAIL_HOST=smtp.mailtrap.io
# MAIL_USER=your-mailtrap-username
# MAIL_PASSWORD=your-mailtrap-password
# Option 3: SendGrid (recommended for production)
# - Sign up at https://sendgrid.com
# - Create an API key
# MAIL_HOST=smtp.sendgrid.net
# MAIL_USER=apikey
# MAIL_PASSWORD=your-sendgrid-api-key
# Option 4: AWS SES (for production)
# MAIL_HOST=email-smtp.us-east-1.amazonaws.com
# MAIL_USER=your-aws-access-key
# MAIL_PASSWORD=your-aws-secret-key
# OPTIONAL: TEMP MAIL (for testing)
# Only needed if using automated testing with Temp Mail API
# TEMP_MAIL_API_KEY=your-temp-mail-api-key


